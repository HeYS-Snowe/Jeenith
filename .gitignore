# Jeenith 构建产物归档：APK/zip 体积大（单包 50MB+），不入版本控制，
# 仅保留构建历史记录。详见 docs/FLUTTER_APK_BUILD_PIPELINE.md Q7。
# 构建产物按平台分类：android/ windows/ 不入版本控制；release_notes/ 与历史记录入库
/builds/*
!/builds/build_history.json
!/builds/release_history.json
!/builds/release_notes/

